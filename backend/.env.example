# Backend environment template for PETEASE
# Copy this to backend/.env and replace the placeholder values.

PORT=5001
JWT_SECRET=replace_with_a_strong_secret

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
